# Data source: yfinance (NSE stocks) or binance (crypto)
DATA_SOURCE=yfinance

# Symbol examples:
# - NSE India stocks on Yahoo Finance: RELIANCE.NS, TCS.NS, INFY.NS
# - Binance crypto pairs: BTC/USDT
SYMBOL=RELIANCE.NS
TIMEFRAME=5m
FAST_MA=9
SLOW_MA=21
RISK_PER_TRADE=0.01
MAX_POSITION_SIZE=10000
POLL_SECONDS=20
LIVE_TRADING=false

# Optional: only used for binance live mode
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
